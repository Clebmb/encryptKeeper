{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "encryptKeeper",
  "version": "0.1.4",
  "identifier": "com.clebmbsoftware.encryptkeeper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "encryptKeeper",
        "width": 1040,
        "height": 560,
        "minWidth": 1040,
        "minHeight": 520,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
